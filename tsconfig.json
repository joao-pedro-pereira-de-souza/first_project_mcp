{
  "compilerOptions": {
    "outDir": "./build",
    "typeRoots": ["./node_modules/@types", "./@types"],
    "target": "ES2023",
    "module": "nodenext",
    "types": ["node"],
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "tests/index.test.js"]
}
